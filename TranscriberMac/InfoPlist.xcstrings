    "NSMicrophoneUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TransLocalAI uses the microphone only when you record audio on your Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "TransLocalAI usa el micrófono solo si grabas un audio desde el Mac."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "extractionState": "manual",
      "localizations": {
