          "stringUnit": {
            "state": "translated",
            "value": "TransLocalAI uses speech recognition to transcribe your meeting audio."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "TransLocalAI usa reconocimiento de voz para transcribir los audios de las reuniones."
