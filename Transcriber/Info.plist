<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.josumartinez.transcriber.transcription</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>100.123.146.23</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>TransLocalAI se conecta con tu Mac (servidor de actas) en la red local o por Tailscale para subir audios y ver transcripciones.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>This app needs access to the microphone to record audio for transcription.</string>
	<key>NSServices</key>
	<array>
		<dict/>
	</array>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>This app uses speech recognition to transcribe your audio files.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
</dict>
</plist>
