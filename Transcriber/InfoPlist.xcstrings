    "NSMicrophoneUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app needs access to the microphone to record audio for transcription."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app necesita acceso al micrófono para grabar audio y transcribirlo."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This app uses speech recognition to transcribe your audio files."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app usa el reconocimiento de voz para transcribir tus archivos de audio."
          }
        }
      }
    },
    "NSSiriUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcriber uses Siri to run your transcription shortcuts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Transcriber usa Siri para ejecutar tus atajos de transcripción."
          }
        }
      }
    }
  }
