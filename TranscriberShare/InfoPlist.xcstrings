    "NSMicrophoneUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This extension needs access to the microphone to record audio for transcription."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta extensión necesita acceso al micrófono para grabar audio y transcribirlo."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This extension uses speech recognition to transcribe your audio files."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta extensión usa el reconocimiento de voz para transcribir tus archivos de audio."
          }
        }
      }
    }
  }
